---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Beraja Remodeling | Construction & Remodeling in Gainesville, FL',
  description = 'Kitchen, bathroom, and whole-home remodeling for Gainesville, FL and surrounding communities. Built with clear communication, premium materials, and careful project management.',
} = Astro.props;

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'HomeAndConstructionBusiness',
  name: 'Beraja Remodeling LLC',
  description,
  telephone: '+1-352-246-3543',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Gainesville',
    addressRegion: 'FL',
    addressCountry: 'US',
  },
  areaServed: ['Gainesville FL', 'Alachua FL', 'Newberry FL', 'High Springs FL', 'Ocala FL'],
  sameAs: ['https://www.facebook.com/profile.php?id=61559592172474'],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#17201d" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="en_US" />
    <title>{title}</title>
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    <!-- Google Fonts preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body>
    <slot />
    <script>
      const setBeforeAfterPosition = (slider: HTMLElement, percentage: number) => {
        const position = Math.max(0, Math.min(100, percentage));
        const beforeImage = slider.querySelector<HTMLElement>('[data-before-after-before]');
        const handle = slider.querySelector<HTMLElement>('[data-before-after-handle]');
        const beforeLabel = slider.querySelector<HTMLElement>('[data-before-after-before-label]');

        if (beforeImage) {
          beforeImage.style.clipPath = `inset(0 ${100 - position}% 0 0)`;
        }

        if (handle) {
          handle.style.left = `${position}%`;
        }

        if (beforeLabel) {
          beforeLabel.style.opacity = position < 10 ? '0' : '1';
        }

        slider.setAttribute('aria-valuenow', String(Math.round(position)));
        slider.setAttribute(
          'aria-valuetext',
          `${Math.round(position)} percent before image visible`
        );
      };

      document.querySelectorAll<HTMLElement>('[data-before-after-slider]').forEach((slider) => {
        if (slider.dataset.beforeAfterReady === 'true') return;

        slider.dataset.beforeAfterReady = 'true';
        let activePointerId: number | null = null;

        const updateFromClientX = (clientX: number) => {
          const rect = slider.getBoundingClientRect();
          const x = Math.max(0, Math.min(clientX - rect.left, rect.width));
          setBeforeAfterPosition(slider, (x / rect.width) * 100);
        };

        slider.addEventListener('pointerdown', (event) => {
          activePointerId = event.pointerId;
          slider.setPointerCapture(event.pointerId);
          updateFromClientX(event.clientX);
        });

        slider.addEventListener('pointermove', (event) => {
          if (activePointerId !== event.pointerId) return;
          updateFromClientX(event.clientX);
        });

        const stopDragging = (event: PointerEvent) => {
          if (activePointerId !== event.pointerId) return;

          if (slider.hasPointerCapture(event.pointerId)) {
            slider.releasePointerCapture(event.pointerId);
          }

          activePointerId = null;
        };

        slider.addEventListener('pointerup', stopDragging);
        slider.addEventListener('pointercancel', stopDragging);
        slider.addEventListener('lostpointercapture', () => {
          activePointerId = null;
        });

        slider.addEventListener('keydown', (event) => {
          if (event.key !== 'ArrowLeft' && event.key !== 'ArrowRight') return;

          event.preventDefault();
          const currentPosition = Number(slider.getAttribute('aria-valuenow') || 50);
          const nextPosition =
            event.key === 'ArrowLeft' ? currentPosition - 5 : currentPosition + 5;
          setBeforeAfterPosition(slider, nextPosition);
        });
      });

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { rootMargin: '-60px' }
      );
      document.querySelectorAll('[data-animate]').forEach((el) => observer.observe(el));
    </script>
  </body>
</html>
