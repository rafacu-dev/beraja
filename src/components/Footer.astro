---
const currentYear = new Date().getFullYear();

const phones = ['+1 352-246-3543', '+1 352-246-5346', '+1 352-246-2103'];
---

<footer class="w-full bg-[#0a0a0a] text-white pt-20 pb-10">
  <div
    class="max-w-7xl mx-auto px-6 md:px-16 grid grid-cols-1 md:grid-cols-3 gap-12 items-start text-center md:text-left"
  >
    <!-- Branding -->
    <div class="flex flex-col items-center md:items-start">
      <div class="flex items-center gap-3 mb-6 text-white">
        <!-- Compass icon -->
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="32"
          height="32"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="text-secondary"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="10"></circle>
          <polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"></polygon>
        </svg>
        <h2 class="font-display text-2xl md:text-3xl tracking-wide leading-tight">
          Beraja<br />Remodeling
        </h2>
      </div>
      <p class="text-white/50 text-body-md max-w-sm">
        Elevando el estándar de la construcción. Transformamos residencias con precisión técnica y
        acabados de élite.
      </p>
    </div>

    <!-- Contact info -->
    <div class="flex flex-col items-center md:items-start md:pl-10">
      <div class="flex items-center gap-3 mb-6 text-white/80">
        <!-- PhoneCall icon -->
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="text-secondary"
          aria-hidden="true"
        >
          <path
            d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.46 2 2 0 0 1 3.6 1.28h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.59a16 16 0 0 0 6 6l.95-.95a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 21.72 16z"
          ></path>
          <path d="M23 11a12 12 0 0 0-12-12"></path>
          <path d="M23 7a8 8 0 0 0-8-8"></path>
          <path d="M23 3a4 4 0 0 0-4-4"></path>
        </svg>
        <h3 class="text-label-caps tracking-widest text-white/70">CONTACTO</h3>
      </div>
      <div class="flex flex-col gap-3">
        {
          phones.map((phone) => (
            <a
              href={`tel:+1${phone.replace(/\D/g, '').slice(1)}`}
              class="text-body-md text-white/80 hover:text-secondary transition-colors font-mono"
            >
              {phone}
            </a>
          ))
        }
      </div>
    </div>

    <!-- Social / Location Links -->
    <div class="flex flex-col items-center md:items-end">
      <h3 class="text-label-caps tracking-widest text-white/70 mb-6">SÍGUENOS</h3>
      <div class="flex items-center gap-4">
        <a
          href="https://www.google.com/maps/place/Beraja+Remodeling+LLC/@29.6803102,-82.2962524,17z"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Nuestra Ubicación"
          class="w-14 h-14 flex items-center justify-center border border-white/20 hover:border-secondary group transition-colors"
        >
          <!-- MapPin icon -->
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="text-white/70 group-hover:text-secondary transition-colors"
            aria-hidden="true"
          >
            <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path>
            <circle cx="12" cy="10" r="3"></circle>
          </svg>
        </a>
        <a
          href="https://www.facebook.com/profile.php?id=61559592172474"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Facebook"
          class="w-14 h-14 flex items-center justify-center border border-white/20 hover:border-secondary group transition-colors"
        >
          <!-- Facebook icon -->
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="text-white/70 group-hover:text-secondary transition-colors"
            aria-hidden="true"
          >
            <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
          </svg>
        </a>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div
    class="max-w-7xl mx-auto px-6 md:px-16 mt-16 md:mt-24 pt-8 border-t border-white/10 flex flex-col md:flex-row items-center justify-between gap-4 text-center md:text-left"
  >
    <p class="text-white/40 text-xs font-sans tracking-wide">
      © {currentYear} Beraja Remodeling LLC. Todos los derechos reservados.
    </p>
    <p class="text-white/40 text-xs font-sans tracking-wide uppercase">
      Quality work you can trust
    </p>
  </div>
</footer>
