---
import { BeforeAfterSlider } from './BeforeAfterSlider';
import beforeImg from '../assets/before.jpg';
import afterImg from '../assets/after.jpg';

const benefits = [
  'Natural light optimization',
  'Certified premium materials',
  'Comprehensive project management',
];
---

<section class="w-full bg-surface-dim/30">
  <div
    class="max-w-7xl mx-auto px-6 md:px-16 py-24 md:py-32 grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center"
  >
    <!-- Text Content -->
    <div data-animate="fade-left" class="flex flex-col">
      <span class="text-label-caps text-secondary mb-4 block">Real Transformation</span>
      <h2
        class="text-display-lg-mobile md:text-headline-lg lg:text-display-lg mb-6 leading-tight"
      >
        The power of<br />transformation
      </h2>
      <p class="text-body-lg text-primary/80 mb-10 max-w-lg">
        See how we revitalize outdated spaces in prestigious residences, preserving the essence
        while elevating functionality and luxury.
      </p>

      <ul class="space-y-4">
        {
          benefits.map((benefit) => (
            <li class="flex items-center gap-4 text-body-md text-primary/90">
              <!-- CheckCircle2 icon -->
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="text-secondary shrink-0"
                aria-hidden="true"
              >
                <path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z" />
                <path d="m9 12 2 2 4-4" />
              </svg>
              <span>{benefit}</span>
            </li>
          ))
        }
      </ul>
    </div>

    <!-- Interactive Slider (React island) -->
    <div data-animate="scale-in" class="w-full shadow-2xl" style="transition-delay: 200ms">
      <BeforeAfterSlider
        beforeImage={beforeImg.src}
        afterImage={afterImg.src}
        client:visible
      />
    </div>
  </div>
</section>
