---
import { BeforeAfterSlider } from './BeforeAfterSlider';
import beforeImg from '../assets/before.jpg';
import afterImg from '../assets/after.jpg';

const benefits = [
  'Local planning for Gainesville-area homes',
  'Material guidance before the first demo day',
  'A cleaner closeout with punch-list accountability',
];
---

<section class="w-full bg-[#eef3ef]">
  <div
    class="max-w-7xl mx-auto px-6 md:px-16 py-20 md:py-28 grid grid-cols-1 lg:grid-cols-2 gap-14 lg:gap-20 items-center"
  >
    <div data-animate="fade-left" class="flex flex-col">
      <span class="text-label-caps text-secondary mb-4 block">A visible transformation</span>
      <h2
        class="text-display-lg-mobile md:text-headline-lg lg:text-display-lg mb-6 leading-tight"
      >
        From empty shell to a room that earns attention.
      </h2>
      <p class="text-body-lg text-primary/80 mb-10 max-w-lg">
        The right remodel should look beautiful, but it also has to work: better light, better
        flow, smarter storage, and finishes that hold up after the reveal.
      </p>

      <ul class="space-y-4">
        {
          benefits.map((benefit) => (
            <li class="flex items-center gap-4 text-body-md text-primary/90">
              <!-- CheckCircle2 icon -->
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="text-secondary shrink-0"
                aria-hidden="true"
              >
                <path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z" />
                <path d="m9 12 2 2 4-4" />
              </svg>
              <span>{benefit}</span>
            </li>
          ))
        }
      </ul>
    </div>

    <div
      data-animate="scale-in"
      class="w-full shadow-[0_30px_80px_rgba(23,32,29,0.24)]"
      style="transition-delay: 200ms"
    >
      <BeforeAfterSlider
        beforeImage={beforeImg.src}
        afterImage={afterImg.src}
        client:visible
      />
    </div>
  </div>
</section>
