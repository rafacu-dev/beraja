---
const services = [
  {
    title: 'Transform Your Kitchen',
    description: 'El corazón de su hogar reinventado con precisión técnica.',
    image:
      'https://images.unsplash.com/photo-1556910103-1c02745aae4d?auto=format&fit=crop&q=80&w=800',
  },
  {
    title: 'Baños de Spa',
    description: 'Santuarios privados diseñados para el bienestar absoluto.',
    image:
      'https://images.unsplash.com/photo-1584622650111-993a426fbf0a?auto=format&fit=crop&q=80&w=800',
  },
  {
    title: 'Transform Your Home',
    description: 'Arquitectura de interiores que fluye con su estilo de vida.',
    image:
      'https://images.unsplash.com/photo-1600210492486-724fe5c67fb0?auto=format&fit=crop&q=80&w=800',
  },
];
---

<section class="w-full max-w-7xl mx-auto px-6 md:px-16 py-24 md:py-32 flex flex-col items-center">
  <div class="services-header text-center mb-16 md:mb-24 opacity-0 translate-y-5">
    <span class="text-label-caps text-secondary mb-4 block">Nuestra Experiencia</span>
    <h2 class="text-display-lg-mobile md:text-display-lg text-primary">Servicios de Élite</h2>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-6 lg:gap-12 w-full">
    {
      services.map((service, index) => (
        <article
          class="service-card flex flex-col group cursor-pointer opacity-0 translate-y-8"
          data-index={index}
        >
          <div class="w-full aspect-[4/5] md:aspect-square lg:aspect-[4/5] overflow-hidden mb-6 relative bg-surface-dim">
            <img
              src={service.image}
              alt={service.title}
              class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
              loading="lazy"
            />
          </div>
          <h3 class="text-headline-md mb-3 text-primary">{service.title}</h3>
          <p class="text-body-md text-primary/70 mb-6 flex-grow">{service.description}</p>
          <a
            href="#proyecto"
            class="text-label-caps text-primary border-b border-primary/30 pb-1 w-fit hover:border-primary transition-colors inline-block"
          >
            VER PROYECTO
          </a>
        </article>
      ))
    }
  </div>
</section>

<script>
  import { animate, inView } from 'motion';

  const header = document.querySelector<HTMLElement>('.services-header');
  if (header) {
    inView(
      header,
      (info) => {
        animate(
          info.target as HTMLElement,
          { opacity: [0, 1], transform: ['translateY(20px)', 'translateY(0px)'] },
          { duration: 0.6 }
        );
      },
      { margin: '-100px' }
    );
  }

  const cards = document.querySelectorAll<HTMLElement>('.service-card');
  cards.forEach((card) => {
    const index = Number(card.dataset.index ?? 0);
    inView(
      card,
      (info) => {
        animate(
          info.target as HTMLElement,
          { opacity: [0, 1], transform: ['translateY(30px)', 'translateY(0px)'] },
          { duration: 0.6, delay: index * 0.2 }
        );
      },
      { margin: '-100px' }
    );
  });
</script>
