---
import heroImage from '../assets/after.jpg';
import { business, content, serviceAreas, type Locale, phoneHref } from '../data/site';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const copy = content[locale];
const primaryPhoneHref = phoneHref(business.phone);
---

<section
  class="relative w-full min-h-[560px] h-[92svh] max-h-[880px] flex flex-col justify-between overflow-hidden bg-primary text-white"
>
  <div class="absolute inset-0 z-0">
    <img
      src={heroImage.src}
      alt={copy.hero.imageAlt}
      class="w-full h-full object-cover object-center md:object-[62%_center]"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(12,18,16,0.88)_0%,rgba(12,18,16,0.62)_43%,rgba(12,18,16,0.16)_100%)]"></div>
    <div class="absolute inset-x-0 bottom-0 h-48 bg-gradient-to-t from-primary to-transparent"></div>
  </div>

  <header class="hero-header relative z-10 w-full px-6 py-5 md:px-12 flex justify-between items-center">
    <div class="flex items-center gap-3 text-white">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="32"
        height="32"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <circle cx="12" cy="12" r="10" />
        <polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76" />
      </svg>
      <h1 class="font-display text-2xl md:text-3xl tracking-wide leading-tight">
        Beraja<br />Remodeling
      </h1>
    </div>
    <a
      href={primaryPhoneHref}
      class="hidden sm:inline-flex items-center justify-center border border-white/35 px-5 py-3 text-button text-white hover:bg-white hover:text-primary transition-colors"
    >
      {copy.cta.call} {business.phone}
    </a>
  </header>

  <div class="relative z-10 w-full px-6 pb-8 md:px-12 md:pb-12 mt-auto">
    <div class="max-w-3xl">
      <p class="text-label-caps text-secondary-light mb-5">
        {copy.hero.eyebrow}
      </p>
      <h2 class="font-display text-[46px] leading-[48px] md:text-[76px] md:leading-[78px] text-white mb-6">
        {copy.hero.heading}
      </h2>
      <p class="text-body-lg text-white/82 max-w-2xl mb-8">
        {copy.hero.body}
      </p>

      <div class="flex flex-col sm:flex-row gap-3 mb-8">
        <a
          href={primaryPhoneHref}
          class="inline-flex items-center justify-center bg-secondary px-6 py-4 text-button text-white hover:bg-secondary-dark transition-colors"
        >
          {copy.cta.estimate}
        </a>
        <a
          href={business.mapUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center border border-white/35 px-6 py-4 text-button text-white hover:bg-white hover:text-primary transition-colors"
        >
          {copy.cta.local}
        </a>
      </div>

      <div class="flex flex-wrap gap-2 text-sm text-white/75">
        <span class="text-white/95">{copy.hero.serving}</span>
        {serviceAreas.map((area) => <span class="border border-white/18 px-3 py-1">{area}</span>)}
      </div>
    </div>
  </div>
</section>
