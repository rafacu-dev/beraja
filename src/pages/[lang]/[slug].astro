---
import ServiceAreaPage from '../../components/ServiceAreaPage.astro';
import { servicePages } from '../../data/site';

export function getStaticPaths() {
  return servicePages.map((page) => ({
    params: {
      lang: page.locale,
      slug: page.slug,
    },
    props: {
      page,
    },
  }));
}

const { page } = Astro.props;
---

<ServiceAreaPage page={page} />
